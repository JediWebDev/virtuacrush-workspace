{
  "name": "virtuacrush",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server.ts",
    "clean:dist": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean:dist && vite build --outDir dist/public && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "start:railway": "node dist/server.cjs",
    "migrate": "tsx db/migrate.ts",
    "clean": "npm run clean:dist",
    "lint": "tsc --noEmit",
    "test": "tsx --test \"server/**/*.test.ts\"",
    "db:reset": "tsx db/reset.ts",
    "jobs:regen-states": "tsx server/jobs/regenerate-states.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@inworld/runtime": "^1.0.6",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-auth": "^1.6.11",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "esbuild": "^0.25.0",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.21.0",
    "phaser": "^4.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.15.1",
    "stripe": "^22.2.0",
    "tailwindcss": "^4.1.14",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
