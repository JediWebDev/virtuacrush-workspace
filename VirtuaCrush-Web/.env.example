# ─── Core ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
PUBLIC_APP_URL=http://localhost:5173

# ─── Database ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/virtuacrush

# ─── Better Auth ─────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=

# ─── Inworld AI ──────────────────────────────────────────────────────────
INWORLD_API_KEY=
INWORLD_MODEL_ID=openai/gpt-4o-mini

# ─── OpenRouter (tone classification & Owl Alpha) ────────────────────────
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ANTHROPIC_API_KEY=   # deprecated — tone classifier uses OpenRouter now

# ─── Stripe ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ─── Frontend (Vite) ─────────────────────────────────────────────────────
VITE_API_URL=

# Dev only — NEVER set to 1 in production
# AUTH_BYPASS=1
