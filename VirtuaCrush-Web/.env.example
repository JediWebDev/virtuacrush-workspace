# ─── Core ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
PUBLIC_APP_URL=http://localhost:5173

# ─── Database ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/virtuacrush

# ─── Better Auth ─────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=

# ─── Inworld AI ──────────────────────────────────────────────────────────
INWORLD_API_KEY=
INWORLD_MODEL_ID=openai/gpt-4o-mini

# ─── Stripe ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ─── Cloudflare R2 (asset storage) ───────────────────────────────────────
# S3 API endpoint WITHOUT the bucket name (account-level URL).
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=virtuacrush
# From an R2 API token with "Object Read Only" permission scoped to the bucket:
# Cloudflare dashboard → R2 → Manage API Tokens → Create API Token
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ─── Social sign-in (optional) ───────────────────────────────────────────
# Configure a provider's credentials AND list it in VITE_OAUTH_PROVIDERS to
# show its button on the auth page. Callback URL to register with the
# provider: <PUBLIC_APP_URL>/api/auth/callback/<provider>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ─── Frontend (Vite) ─────────────────────────────────────────────────────
VITE_API_URL=
# Comma-separated providers to show on the auth page, e.g. "google,discord"
VITE_OAUTH_PROVIDERS=

# Dev only — NEVER set to 1 in production
# AUTH_BYPASS=1
# Log every full LLM prompt (Railway logs + GET /api/dev/llm-prompts when logged in)
# LLM_LOG_PROMPTS=1

# ─── LLM (OpenAI-compatible: OpenRouter, Groq, DeepSeek, etc.) ───────────
# LLM_PROVIDER=openrouter
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=
# LLM_MODEL=deepseek/deepseek-v4-flash
# Faster/cheap model for intent referee (~200 tokens out)
# LLM_REFEREE_MODEL=deepseek/deepseek-v3.2
# LLM_REFEREE_MAX_TOKENS=220
# LLM_REFEREE_TEMPERATURE=0.2
# Prefix caching: keep persona + roleplay rules in the stable system message (director
# path splits system vs user automatically). Turn 2+ should show cached > 0 in logs.
